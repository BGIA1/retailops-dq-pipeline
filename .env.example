# RetailDQ local configuration example.
# Copy to .env only for local non-secret overrides. Never commit real credentials.

RETAILDQ_CONFIG=configs/local.yaml
RETAILDQ_LOG_LEVEL=INFO

# Azure placeholders for future manual deployment workflows only.
# Do not place real values in repository files.
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_RESOURCE_GROUP=rg-retaildq-demo-placeholder
AZURE_LOCATION=eastus
